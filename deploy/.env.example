# Runtime-only env contract for deploy/docker-compose.yml.
# Keep the real env file outside Git and pass it with:
#   docker compose --env-file /secure/path/infra.deploy.env -f deploy/docker-compose.yml up -d

# --- DATABASE / TOKENS ---
POSTGRES_PASSWORD=replace-with-strong-random-password
JWT_SECRET=replace-with-strong-random-secret
JWT_ALG=HS256
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14
BOOTSTRAP_ADMIN_TOKEN=replace-with-strong-internal-token

# --- PRODUCT / AUTH ---
SITE_URL=https://stellcodex.com
AUTH_SESSION_COOKIE_NAME=stellcodex_session
AUTH_SESSION_TTL_MINUTES=43200
AUTH_SEED_ADMIN_EMAIL=admin@example.com
AUTH_SEED_ADMIN_PASSWORD=replace-with-strong-admin-password
AUTH_SEED_ADMIN_FULL_NAME=Admin User
AUTH_SEED_MEMBER_EMAIL=member@example.com
AUTH_SEED_MEMBER_PASSWORD=replace-with-strong-member-password
AUTH_SEED_MEMBER_FULL_NAME=Member User

# --- GOOGLE AUTH ---
GOOGLE_ADMIN_WHITELIST=admin@example.com
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=https://stellcodex.com/api/v1/auth/google/callback

# --- FILE / PLATFORM LIMITS ---
FEATURE_FILES=true
MAX_UPLOAD_BYTES=104857600
RATE_LIMIT_PER_HOUR=2000
ALLOWED_CONTENT_TYPES=model/stl,model/step,model/iges,application/step,application/iges,application/pdf,image/png,image/jpeg,model/gltf-binary,model/gltf+json,application/octet-stream,text/plain

# --- CANONICAL REPO ROOTS ---
STELLCODEX_REPO_ROOT=/srv/stellcodex
STELLAI_REPO_ROOT=/srv/stell-ai
ORCHESTRA_REPO_ROOT=/srv/orchestra

# --- OBJECT STORAGE ---
STELLCODEX_S3_ACCESS_KEY_ID=replace-with-random-access-key
STELLCODEX_S3_SECRET_ACCESS_KEY=replace-with-random-secret-key
STELLCODEX_S3_REGION=us-east-1
STELLCODEX_S3_BUCKET=stellcodex
PUBLIC_S3_BASE_URL=https://stellcodex.com
